Add raw VGA-memory + DGROUP-region one-shot dumps to the BUMPYCAP hook.
Used by tools/dosbox/extract_menu_strips.sh to capture the menu difficulty
strips from the original, and to decode the original's pages offline.
Applied AFTER 01-bumpycap-hook.patch (extends the same shot block).

diff --git a/src/hardware/vga_draw.cpp b/src/hardware/vga_draw.cpp
index ee12d0f..4babe32 100644
--- a/src/hardware/vga_draw.cpp
+++ b/src/hardware/vga_draw.cpp
@@ -6113,6 +6113,56 @@ static void VGA_VerticalTimer(Bitu /*val*/) {
 			}
 		}
 
+		/* DIAG raw dumps at frame>=BUMPYCAP_SHOT_FRAME (one-shot each):
+		 *  BUMPYCAP_RAWVGA_OUT  — raw vga.mem.linear[0..0x10000] (65536 B), so the
+		 *                         original's menu page can be decoded offline without
+		 *                         the present-model page assumption the SHOT path makes.
+		 *  BUMPYCAP_MEMDUMP_OUT  — raw phys[dg + MEMDUMP_OFF .. +MEMDUMP_LEN], for
+		 *                         extracting DGROUP buffers (e.g. the menu option strips). */
+		{
+			static int rv_done = 0, md_done = 0, dmp_init = 0;
+			static unsigned dmp_frame = 0xFFFFFFFFu;
+			static const char *rawvga_out = 0, *memdump_out = 0;
+			static unsigned memdump_off = 0u, memdump_len = 0u;
+			if (!dmp_init) {
+				dmp_init = 1;
+				const char *e = getenv("BUMPYCAP_SHOT_FRAME");
+				if (e) dmp_frame = (unsigned)strtoul(e, 0, 0);
+				rawvga_out  = getenv("BUMPYCAP_RAWVGA_OUT");
+				memdump_out = getenv("BUMPYCAP_MEMDUMP_OUT");
+				if ((e = getenv("BUMPYCAP_MEMDUMP_OFF")) != NULL) memdump_off = (unsigned)strtoul(e, 0, 0);
+				if ((e = getenv("BUMPYCAP_MEMDUMP_LEN")) != NULL) memdump_len = (unsigned)strtoul(e, 0, 0);
+			}
+			if (!rv_done && rawvga_out && bumpycap_frame >= dmp_frame && vga.mem.linear != NULL) {
+				rv_done = 1;
+				FILE *rf = fopen(rawvga_out, "wb");
+				if (rf) {
+					const uint32_t pm = vga.mem.memmask ? vga.mem.memmask : 0xFFFFFu;
+					uint32_t i;
+					for (i = 0; i < 0x10000u; i++) {
+						uint8_t b = vga.mem.linear[i & pm];
+						fwrite(&b, 1, 1, rf);
+					}
+					unsigned st = ((unsigned)vga.crtc.start_address_high << 8) | (unsigned)vga.crtc.start_address_low;
+					fclose(rf);
+					LOG_MSG("BUMPYRAWVGA wrote %s at frame %u start=0x%04x", rawvga_out, bumpycap_frame, st);
+				}
+			}
+			if (!md_done && memdump_out && memdump_len && bumpycap_frame >= dmp_frame) {
+				md_done = 1;
+				FILE *mf = fopen(memdump_out, "wb");
+				if (mf) {
+					unsigned i;
+					for (i = 0; i < memdump_len; i++) {
+						uint8_t b = phys_readb(dg + (PhysPt)memdump_off + (PhysPt)i);
+						fwrite(&b, 1, 1, mf);
+					}
+					fclose(mf);
+					LOG_MSG("BUMPYMEMDUMP wrote %s at frame %u dg+0x%x len %u", memdump_out, bumpycap_frame, memdump_off, memdump_len);
+				}
+			}
+		}
+
 		/* One-shot dump of the live joystick/key handler script for handler 0
 		 * (g_joystick_handler_table @ DGROUP:0x4cf2 = 16 far ptrs), so we can decode
 		 * the scancode -> input_state mapping the menu uses (read_input_action),
