+/* ════════════════════════════════════════════════════════════════════════════
+ *  BUMPYCAP FRAMEBUFFER capture (Plan-A Task 10) — the rendered-pixel companion
+ *  to the int8-SNAP state capture above.  Dumps the VGA A000 4-plane framebuffer
+ *  per gameplay tick so the playable BUMPYP.EXE's rendered frames can be diffed
+ *  pixel-for-pixel against the ORIGINAL BUMPY.EXE's (the Task-11 frame-compare
+ *  gate).  Independent of, and additive to, 01 (VGA log/inject) and 02 (int8).
+ *  ----------------------------------------------------------------------------
+ *  TRIGGER: shares the int8 boundary — the innermost per-tick loop TOP of
+ *  game_loop (runtime cs=0x0824 ip=0x0cda) — so an FB frame corresponds 1:1 to
+ *  the int8 tick at the same loop iteration (the just-presented frame: the engine
+ *  has rendered + page-flipped the prior tick by the time it loops back to top).
+ *  Because the playable relink has DIFFERENT code offsets, the trigger CS:IP is
+ *  ENV-OVERRIDABLE (BUMPYCAP_FB_TRIG_CS / BUMPYCAP_FB_TRIG_IP, hex), default =
+ *  the original's 0x0824:0x0cda.  Arming reuses the in-level gate
+ *  (current_level >= 1 && game_mode != 0), honoring the 01-overridable offsets.
+ *
+ *  VGA PLANAR READ: mode 0x0D is 4 bit-planes, all at segment 0xA000.  dosbox-x
+ *  does NOT store VGA RAM in the system memory image, so phys_readb(0xA0000) is
+ *  WRONG here (it reads unmapped system RAM = 0xFF).  Instead we read the VGA
+ *  framebuffer the same way the renderer does: from vga.mem.linear[], which holds
+ *  the 4 planes INTERLEAVED as one byte each per "byte offset" (the EGA latch
+ *  layout — ((uint32_t*)vga.mem.linear)[off] is the 4-plane dword, latch.b[P] is
+ *  plane P; see VGA_Generic_Read_Handler in src/hardware/vga_memory.cpp).  So
+ *  plane P at byte offset `off` = vga.mem.linear[(off*4 + P) & memmask].  This is
+ *  hardware-faithful AND identical for the original and the playable binary.
+ *  The DISPLAYED page is selected by the CRTC Start Address (vga.crtc
+ *  start_address_high/low, in WORD units): page0 -> byte 0, page1 -> byte 0x2000
+ *  (CRTC word 0x1000).  The original double-buffers A000(page0)/A200(page1) at the
+ *  same linear addresses; we read the CURRENTLY-DISPLAYED page (the just-presented
+ *  frame) so playable & original capture the same logical frame.  We read
+ *  VGA_PLANE_BYTES = 0x1F40 (8000 = 320*200/8, the visible area) bytes per plane.
+ *
+ *  RECORD: per frame = 4 planes x 0x1F40 bytes, plane order 0,1,2,3 (no header —
+ *  a flat raw stream).  Total file = frames * 4 * 0x1F40.  Lifecycle mirrors the
+ *  int8 emitter: env-gated init, in-level arm, one record per armed hit, then
+ *  flush/close + DoKillSwitch() after N frames.  Gated behind BUMPYCAP_FB_OUT
+ *  (output path) + BUMPYCAP_FB_FRAMES (N); inert when unset.
+ * ════════════════════════════════════════════════════════════════════════════ */
+#define BUMPYCAP_VGA_PLANE_BYTES  0x1F40u   /* 8000 = 320*200/8 (visible area) */
+
+/* bumpycap_fb_boundary — per-tick-loop-top FB capture.  Arms in a real level,
+ * dumps the displayed page's 4 planes (0x1F40 bytes each) per armed hit, exits
+ * after N frames.  Env-overridable trigger CS:IP is checked by the caller. */
+static void bumpycap_fb_boundary(void) {
+	static int      fb_inited = 0;
+	static int      fb_enabled = 0;
+	static FILE    *fb_fp = NULL;
+	static unsigned fb_frames_target = 0;
+	static unsigned fb_count = 0;
+	static int      fb_armed = 0;
+	static int      fb_done = 0;
+	/* arming offsets — default ORIGINAL, but honor the 01-overridable env so the
+	 * playable build (different DGROUP layout) arms correctly too. */
+	static unsigned fb_off_curlevel = 0x79b2u;
+	static unsigned fb_off_gamemode = 0x792cu;
+	/* arming DGROUP base — default the ORIGINAL's (BUMPYCAP_DG=0x185f0), but
+	 * env-overridable via BUMPYCAP_DGROUP (hex paragraph, same env patch 01 uses)
+	 * so the playable BUMPYP.EXE (runtime DGROUP 0x3fe4, a different relink) arms
+	 * on ITS current_level/game_mode, not the original's load address.  Default
+	 * unchanged => the int8/original FB path is unaffected. */
+	static PhysPt fb_dg = BUMPYCAP_DG;
+
+	if (!fb_inited) {
+		fb_inited = 1;
+		const char *out = getenv("BUMPYCAP_FB_OUT");
+		const char *nf  = getenv("BUMPYCAP_FB_FRAMES");
+		const char *e;
+		if ((e = getenv("BUMPYCAP_DGROUP")) != NULL) {
+			unsigned dgpara = 0u;
+			if (sscanf(e, "%x", &dgpara) == 1) fb_dg = (PhysPt)(dgpara << 4);
+		}
+		if ((e = getenv("BUMPYCAP_OFF_CURLEVEL")) != NULL) sscanf(e, "%x", &fb_off_curlevel);
+		if ((e = getenv("BUMPYCAP_OFF_GAMEMODE")) != NULL) sscanf(e, "%x", &fb_off_gamemode);
+		if (out != NULL && *out != '\0') {
+			fb_frames_target = (nf != NULL) ? (unsigned)strtoul(nf, NULL, 0) : 0u;
+			if (fb_frames_target == 0u) fb_frames_target = 150u;   /* match int8 default cadence */
+			fb_fp = fopen(out, "wb");
+			if (fb_fp != NULL) {
+				fb_enabled = 1;
+				LOG_MSG("BUMPYCAP fb: capturing %u frames (4 x %u bytes/plane) to %s",
+					fb_frames_target, (unsigned)BUMPYCAP_VGA_PLANE_BYTES, out);
+			} else {
+				LOG_MSG("BUMPYCAP fb: cannot open %s for write", out);
+			}
+		}
+	}
+	if (!fb_enabled || fb_done) return;
+
+	/* Arm only inside a real level — same gate as the int8 capture.  Reads from
+	 * fb_dg (BUMPYCAP_DGROUP-overridable) so the playable build arms correctly. */
+	if (!fb_armed) {
+		uint8_t cur = phys_readb(fb_dg + (PhysPt)fb_off_curlevel);
+		uint8_t gm  = phys_readb(fb_dg + (PhysPt)fb_off_gamemode);
+		if (cur < 1u || gm == 0u) return;
+		fb_armed = 1;
+	}
+
+	/* Displayed page byte offset = CRTC Start Address (word units) * 2.  The
+	 * original flips between word 0 (page0/A000) and word 0x1000 (page1/A200);
+	 * mask to the A000 16KB aperture so the read stays in the displayed page. */
+	if (vga.mem.linear != NULL) {
+		unsigned start = ((unsigned)vga.crtc.start_address_high << 8)
+			| (unsigned)vga.crtc.start_address_low;
+		unsigned page_off = (start << 1) & 0x3FFFu;   /* byte offset within A000 */
+		const uint32_t pmask = vga.mem.memmask ? vga.mem.memmask : 0xFFFFFu;
+
+		uint8_t buf[BUMPYCAP_VGA_PLANE_BYTES];
+		for (unsigned plane = 0; plane < 4u; plane++) {
+			/* dosbox-x stores the 4 planes INTERLEAVED in vga.mem.linear[] — one
+			 * byte per plane per byte-offset (the EGA latch dword).  Plane P at
+			 * byte offset `off` = vga.mem.linear[(off*4 + P) & memmask], which is
+			 * exactly what VGA_Generic_Read_Handler returns as latch.b[P]. */
+			for (unsigned i = 0; i < BUMPYCAP_VGA_PLANE_BYTES; i++) {
+				uint32_t li = (((uint32_t)(page_off + i)) << 2) + plane;
+				buf[i] = vga.mem.linear[li & pmask];
+			}
+			fwrite(buf, 1, BUMPYCAP_VGA_PLANE_BYTES, fb_fp);
+		}
+	} else {
+		/* VGA RAM not allocated (shouldn't happen mid-level): emit zeros so the
+		 * record count / file size stays consistent for the frame-compare gate. */
+		uint8_t zero[BUMPYCAP_VGA_PLANE_BYTES];
+		memset(zero, 0, sizeof zero);
+		for (unsigned plane = 0; plane < 4u; plane++)
+			fwrite(zero, 1, BUMPYCAP_VGA_PLANE_BYTES, fb_fp);
+	}
+	fb_count++;
+	if (fb_count >= fb_frames_target) {
+		fflush(fb_fp);
+		fclose(fb_fp);
+		fb_fp = NULL;
+		fb_done = 1;
+		LOG_MSG("BUMPYCAP fb: captured %u frames; requesting exit", fb_count);
+		DoKillSwitch();   /* clean shutdown (throw 1, caught by the main loop) */
+	}
+}
