+/* bumpycap_int8_boundary — called once per per-tick-loop top (cs:ip trigger).
+ * Arms only in a real level; writes header+INIT+FRAME[0] on the first armed hit,
+ * one FRAME[k] per subsequent hit; after N tick-frames flushes, closes, and
+ * requests a clean emulator exit. */
+static void bumpycap_int8_boundary(void) {
+	static int    bc_inited = 0;
+	static int    bc_enabled = 0;
+	static FILE  *bc_fp = NULL;
+	static unsigned bc_frames_target = 0;    /* N tick frames */
+	static unsigned bc_tick_count = 0;       /* tick frames written so far (FRAME[1..N]) */
+	static int    bc_armed = 0;
+	static int    bc_done = 0;
+
+	if (!bc_inited) {
+		bc_inited = 1;
+		const char *out = getenv("BUMPYCAP_INT8_OUT");
+		const char *nf  = getenv("BUMPYCAP_INT8_FRAMES");
+		if (out != NULL && *out != '\0') {
+			bc_frames_target = (nf != NULL) ? (unsigned)strtoul(nf, NULL, 0) : 0u;
+			if (bc_frames_target == 0u) bc_frames_target = 40u;   /* sane default */
+			bc_fp = fopen(out, "wb");
+			if (bc_fp != NULL) {
+				bc_enabled = 1;
+				LOG_MSG("BUMPYCAP int8: capturing %u frames to %s", bc_frames_target, out);
+			} else {
+				LOG_MSG("BUMPYCAP int8: cannot open %s for write", out);
+			}
+		}
+	}
+	if (!bc_enabled || bc_done) return;
+
+	/* Arm only inside a real level (skip title/menu loop-top hits, where the
+	 * inner per-tick loop is not the gameplay loop).  current_level >= 1 and a
+	 * non-zero game_mode = gameplay engaged. */
+	if (!bc_armed) {
+		uint8_t cur = bumpycap_rdb(OFF_CURRENT_LEVEL);
+		uint8_t gm  = bumpycap_rdb(OFF_GAME_MODE);
+		if (cur < 1u || gm == 0u) return;
+		bc_armed = 1;
+
+		/* First armed hit: header + INIT + FRAME[0]. */
+		uint8_t hdr[BUMPYCAP_HEADER_SIZE];
+		uint8_t *hp = hdr;
+		bc_put8(&hp, 'B'); bc_put8(&hp, 'I'); bc_put8(&hp, 'N'); bc_put8(&hp, 'T');
+		bc_put16(&hp, (uint16_t)BUMPYCAP_INT8_VERSION);
+		bc_put16(&hp, (uint16_t)0x185f);                    /* dgroup_seg */
+		bc_put16(&hp, (uint16_t)bc_frames_target);          /* frame_count = N */
+		bc_put16(&hp, (uint16_t)BUMPYCAP_INIT_SIZE);        /* init_size  */
+		bc_put16(&hp, (uint16_t)BUMPYCAP_FRAME_SIZE);       /* frame_stride */
+		fwrite(hdr, 1, BUMPYCAP_HEADER_SIZE, bc_fp);
+
+		/* INIT: tilemap[0x300] + anim_channels[84] + entity_state[0x200] + scalars. */
+		{
+			uint16_t tm_off = bumpycap_rdw(OFF_TILEMAP_PTR);
+			uint16_t tm_seg = bumpycap_rdw(OFF_TILEMAP_PTR + 2);
+			PhysPt lin = (PhysPt)(((uint32_t)tm_seg << 4) + tm_off);
+			for (unsigned i = 0; i < BUMPYCAP_TILEMAP_SIZE; i++) {
+				uint8_t b = phys_readb(lin + (PhysPt)i);
+				fwrite(&b, 1, 1, bc_fp);
+			}
+		}
+		{
+			uint8_t anim[BUMPYCAP_ANIM_RECS_LEN];
+			bumpycap_read_anim_records(anim);
+			fwrite(anim, 1, BUMPYCAP_ANIM_RECS_LEN, bc_fp);
+		}
+		{
+			/* entity_state[0x200]: now carries the P1/P2 sprite-object descriptor
+			   pointee blocks (INT8_VERSION 2).  p1_update_grid_cell / p2_update_grid_cell
+			   read the sprite origin words at pointee+0x14/+0x16, which feed the COMPARED
+			   grid-cell scalars — so those descriptor bytes are a genuine read-set input.
+			   Layout: [0x00..0x40) = p1_sprite pointee, [0x40..0x80) = p2_sprite pointee,
+			   rest reserved zeros.  Each block is read via its DGROUP far ptr (off,seg). */
+			uint8_t ent[BUMPYCAP_ENTITY_LEN];
+			memset(ent, 0, sizeof ent);
+			for (int s = 0; s < 2; s++) {
+				unsigned fp = (s == 0) ? OFF_P1_SPRITE_FP : OFF_P2_SPRITE_FP;
+				uint16_t off = bumpycap_rdw(fp);
+				uint16_t seg = bumpycap_rdw(fp + 2);
+				PhysPt lin = (PhysPt)(((uint32_t)seg << 4) + off);
+				for (unsigned i = 0; i < BUMPYCAP_SPRITE_DESC_LEN; i++)
+					ent[(unsigned)s * BUMPYCAP_SPRITE_DESC_LEN + i] = phys_readb(lin + (PhysPt)i);
+			}
+			fwrite(ent, 1, BUMPYCAP_ENTITY_LEN, bc_fp);
+		}
+		{
+			/* move_data[0x4600]: the low-DGROUP static-data window @0x0000
+			   (move-script tbl+arrays AND the cell-animation tiledef/frame/grid/pos
+			   tbls + their tile-def/frame/stream blobs), read byte-exact from the live
+			   (loader-relocated) DGROUP so EVERY far-pointer move/anim read resolves
+			   1:1 (INT8_VERSION 3). */
+			for (unsigned i = 0; i < BUMPYCAP_MOVE_DATA_LEN; i++) {
+				uint8_t b = bumpycap_rdb(BUMPYCAP_MOVE_DATA_OFF + i);
+				fwrite(&b, 1, 1, bc_fp);
+			}
+		}
+		{
+			uint8_t sc[BUMPYCAP_SCALARS_SIZE];
+			uint8_t *sp = sc;
+			bumpycap_emit_scalars(&sp);
+			fwrite(sc, 1, BUMPYCAP_SCALARS_SIZE, bc_fp);
+		}
+
+		/* FRAME[0]: mirror of INIT scalars (rng/input = seed values). */
+		{
+			uint8_t fr[BUMPYCAP_FRAME_SIZE];
+			uint8_t *fp = fr;
+			bumpycap_emit_frame(&fp);
+			fwrite(fr, 1, BUMPYCAP_FRAME_SIZE, bc_fp);
+		}
+		return;
+	}
+
+	/* Subsequent armed hits: one FRAME[k] per tick (trailing rng/input + state). */
+	{
+		uint8_t fr[BUMPYCAP_FRAME_SIZE];
+		uint8_t *fp = fr;
+		bumpycap_emit_frame(&fp);
+		fwrite(fr, 1, BUMPYCAP_FRAME_SIZE, bc_fp);
+	}
+	bc_tick_count++;
+	if (bc_tick_count >= bc_frames_target) {
+		fflush(bc_fp);
+		fclose(bc_fp);
+		bc_fp = NULL;
+		bc_done = 1;
+		LOG_MSG("BUMPYCAP int8: captured %u tick frames; requesting exit", bc_tick_count);
+		DoKillSwitch();   /* clean shutdown (throw 1, caught by the main loop) */
+	}
+}
+
 bool DEBUG_HeavyIsBreakpoint(void) {
+	/* BUMPYCAP int8-SNAP frame-boundary trigger: the innermost per-tick loop top
+	 * of game_loop (runtime cs=0x0824, ip=0x0cda).  Additional to the 01 VGA hook;
+	 * no-op unless BUMPYCAP_INT8_OUT is set (env-gated inside the callee). */
+	if (SegValue(cs) == BUMPYCAP_TICK_SEG && reg_ip == BUMPYCAP_TICK_OFF) {
+		bumpycap_int8_boundary();
+	}
+
 	if (cpuLog) {
 		if (cpuLogCounter>0) {
 			LogInstruction(SegValue(cs),reg_eip,cpuLogFile);
