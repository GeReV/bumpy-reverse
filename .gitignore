# Everything non-source lives under local/ (toolchain, game data, build
# intermediates, downloads, planning) — regenerable or not distributable.
/local/

# Generated outputs (level PNGs, sprite sheets, JSON) — regenerable from the game files.
/results/

# Build cruft
__pycache__/
*.pyc
*.obj
*.o
*.lst
/src/play/
# worktree-local build output (Makefile BUMPY_OUTDIR override; default lands in /local/)
/src/out/

# Root dotfiles (sandbox-mounted shell/editor/agent config — not part of the repo)
/.*
!/.gitignore
